{
  "name": "personal-context-mcp",
  "version": "0.1.4",
  "description": "MCP server that exposes your personal context (profile, blogs, GitHub, projects) to any AI agent.",
  "type": "module",
  "bin": {
    "personal-context-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "personal-context",
    "devrel",
    "llm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "author": "Ayush Kumar <ayushknj3@gmail.com>",
  "homepage": "https://github.com/Ayush7614/personal-context#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ayush7614/personal-context.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@personal-context/core": "workspace:*"
  }
}
